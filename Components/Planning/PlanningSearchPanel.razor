<section class="planning-search">
    <div class="planning-search-form">
        <label class="field-label">Keyword search criteria</label>
        <div class="planning-search-criteria">
            @for (var index = 0; index < Criteria.Count; index++)
            {
                var criterion = Criteria[index];
                <div class="planning-search-criterion" @key="criterion">
                    <div class="planning-search-row">
                        <div class="planning-search-input">
                            <input id="@GetSearchCriterionInputId(index)"
                                   class="text-input"
                                   placeholder="@GetSearchCriterionPlaceholder(index)"
                                   aria-label="@GetSearchCriterionLabel(index)"
                                   @bind="criterion.Text"
                                   @bind:event="oninput"
                                   @onkeydown="HandleKeywordKeyDownAsync" />
                            <button class="icon-button search-settings-button"
                                    type="button"
                                    title="Search settings"
                                    aria-label="@GetSearchCriterionSettingsLabel(index)"
                                    aria-haspopup="dialog"
                                    @onclick="() => OpenSettingsAsync(criterion)">
                                <span aria-hidden="true">&#9881;</span>
                            </button>
                            <button class="secondary-button or-keyword-button"
                                    type="button"
                                    title="Add OR keyword"
                                    aria-label="@GetAddOrKeywordLabel(index)"
                                    @onclick="() => AddOrKeyword(criterion)"
                                    disabled="@IsSearching">
                                OR
                            </button>
                        </div>
                        @if (Criteria.Count > 1)
                        {
                            <button class="secondary-button" type="button" @onclick="() => RemoveCriterionAsync(criterion)" disabled="@IsSearching">
                                Remove
                            </button>
                        }
                    </div>
                    @for (var orIndex = 0; orIndex < criterion.OrKeywords.Count; orIndex++)
                    {
                        var orKeyword = criterion.OrKeywords[orIndex];
                        <div class="planning-search-row planning-search-or-row" @key="orKeyword">
                            <span class="or-keyword-label" aria-hidden="true">OR</span>
                            <div class="planning-search-input">
                                <input id="@GetOrKeywordInputId(index, orIndex)"
                                       class="text-input"
                                       placeholder="Alternative keyword criteria"
                                       aria-label="@GetOrKeywordLabel(index, orIndex)"
                                       @bind="orKeyword.Text"
                                       @bind:event="oninput"
                                       @onkeydown="HandleKeywordKeyDownAsync" />
                                <button class="secondary-button or-keyword-button"
                                        type="button"
                                        title="Add OR keyword"
                                        aria-label="@GetAddOrKeywordLabel(index)"
                                        @onclick="() => AddOrKeyword(criterion)"
                                        disabled="@IsSearching">
                                    OR
                                </button>
                            </div>
                            <button class="secondary-button" type="button" @onclick="() => RemoveOrKeyword(criterion, orKeyword)" disabled="@IsSearching">
                                Remove
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

        <PlanningActiveFilterChips DateFilter="@DateFilter"
                                   LocationFilter="@LocationFilter"
                                   IsBusy="@IsSearchBusy"
                                   OnClearDateFilter="OnClearDateFilter"
                                   OnClearLocationFilter="OnClearLocationFilter"
                                   OnClearAllFilters="OnClearAllFilters" />

        <div class="planning-search-actions">
            <button class="secondary-button filter-button" type="button" @onclick="OpenFiltersModal" disabled="@IsSearchBusy" aria-haspopup="dialog">
                <span>Filters</span>
                @if (ActiveFilterCount > 0)
                {
                    <span class="filter-count">@ActiveFilterCount</span>
                }
            </button>
            <button class="secondary-button" type="button" @onclick="OnAddCriterion" disabled="@IsSearching">
                Add criterion
            </button>
            <button class="primary-button" type="button" @onclick="SearchAsync" disabled="@IsSearchBusy">
                @SearchButtonLabel
            </button>
            @if (SearchHasRun)
            {
                <button class="secondary-button" type="button" @onclick="OnClear">
                    Clear
                </button>
            }
        </div>
    </div>

    @if (SearchHasRun && !IsSearching)
    {
        <p class="search-summary">
            @SearchPaginationSummary for <strong>@LastSearchText</strong>
        </p>
    }
</section>

@if (_isFiltersModalOpen)
{
    <PlanningFiltersModal DateFilter="@DateFilter"
                          LocationFilter="@LocationFilter"
                          IsBusy="@IsSearchBusy"
                          OnOpenDates="OpenDateFilterModal"
                          OnOpenLocation="OpenLocationFilterModal"
                          OnClearAllFilters="OnClearAllFilters"
                          OnClose="CloseFilterModals" />
}

@if (_isDateFilterModalOpen)
{
    <PlanningDateRangeFilterModal Filter="@DateFilter"
                                  IsBusy="@IsSearchBusy"
                                  OnClear="OnClearDateFilter"
                                  OnBack="BackToFiltersModal"
                                  OnClose="CloseFilterModals" />
}

@if (_isLocationFilterModalOpen)
{
    <PlanningLocationFilterModal Filter="@LocationFilter"
                                 IsBusy="@IsSearchBusy"
                                 IsFindingAuthorities="@IsFindingLocationAuthorities"
                                 ErrorMessage="@LocationErrorMessage"
                                 OnFindAuthorities="OnFindLocationAuthorities"
                                 OnClear="OnClearLocationFilter"
                                 OnBack="BackToFiltersModal"
                                 OnClose="CloseFilterModals" />
}

@code {
    private bool _isFiltersModalOpen;
    private bool _isDateFilterModalOpen;
    private bool _isLocationFilterModalOpen;

    [Parameter]
    public IList<PlanningSearchCriterionInput> Criteria { get; set; } = [];

    [Parameter]
    public PlanningDateRangeFilterInput DateFilter { get; set; } = new();

    [Parameter]
    public PlanningLocationFilterInput LocationFilter { get; set; } = new();

    [Parameter]
    public bool IsSearching { get; set; }

    [Parameter]
    public bool IsFindingLocationAuthorities { get; set; }

    [Parameter]
    public string? LocationErrorMessage { get; set; }

    [Parameter]
    public bool SearchHasRun { get; set; }

    [Parameter]
    public string? LastSearchText { get; set; }

    [Parameter]
    public string SearchPaginationSummary { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnSearch { get; set; }

    [Parameter]
    public EventCallback OnAddCriterion { get; set; }

    [Parameter]
    public EventCallback<PlanningSearchCriterionInput> OnRemoveCriterion { get; set; }

    [Parameter]
    public EventCallback<PlanningSearchCriterionInput> OnOpenSettings { get; set; }

    [Parameter]
    public EventCallback OnClear { get; set; }

    [Parameter]
    public EventCallback OnClearDateFilter { get; set; }

    [Parameter]
    public EventCallback OnFindLocationAuthorities { get; set; }

    [Parameter]
    public EventCallback OnClearLocationFilter { get; set; }

    [Parameter]
    public EventCallback OnClearAllFilters { get; set; }

    private string SearchButtonLabel => IsSearching ? "Searching..." : "Search";

    private bool IsSearchBusy => IsSearching || IsFindingLocationAuthorities;

    private int ActiveFilterCount => (DateFilter.HasActive ? 1 : 0) + (LocationFilter.HasResolved ? 1 : 0);

    private Task SearchAsync()
    {
        return OnSearch.InvokeAsync();
    }

    private Task RemoveCriterionAsync(PlanningSearchCriterionInput criterion)
    {
        return OnRemoveCriterion.InvokeAsync(criterion);
    }

    private Task OpenSettingsAsync(PlanningSearchCriterionInput criterion)
    {
        return OnOpenSettings.InvokeAsync(criterion);
    }

    private void AddOrKeyword(PlanningSearchCriterionInput criterion)
    {
        if (IsSearching)
        {
            return;
        }

        criterion.OrKeywords.Add(new PlanningSearchKeywordInput());
    }

    private void RemoveOrKeyword(PlanningSearchCriterionInput criterion, PlanningSearchKeywordInput keyword)
    {
        if (IsSearching)
        {
            return;
        }

        criterion.OrKeywords.Remove(keyword);
    }

    private Task HandleKeywordKeyDownAsync(KeyboardEventArgs args)
    {
        return string.Equals(args.Key, "Enter", StringComparison.OrdinalIgnoreCase)
            ? SearchAsync()
            : Task.CompletedTask;
    }

    private void OpenFiltersModal()
    {
        _isFiltersModalOpen = true;
        _isDateFilterModalOpen = false;
        _isLocationFilterModalOpen = false;
    }

    private void OpenDateFilterModal()
    {
        _isFiltersModalOpen = false;
        _isDateFilterModalOpen = true;
        _isLocationFilterModalOpen = false;
    }

    private void OpenLocationFilterModal()
    {
        _isFiltersModalOpen = false;
        _isDateFilterModalOpen = false;
        _isLocationFilterModalOpen = true;
    }

    private void BackToFiltersModal()
    {
        _isFiltersModalOpen = true;
        _isDateFilterModalOpen = false;
        _isLocationFilterModalOpen = false;
    }

    private void CloseFilterModals()
    {
        _isFiltersModalOpen = false;
        _isDateFilterModalOpen = false;
        _isLocationFilterModalOpen = false;
    }

    private static string GetSearchCriterionInputId(int index)
    {
        return $"planning-keyword-{index}";
    }

    private static string GetSearchCriterionLabel(int index)
    {
        return $"Keyword search criterion {index + 1}";
    }

    private static string GetSearchCriterionSettingsLabel(int index)
    {
        return $"Open settings for keyword search criterion {index + 1}";
    }

    private static string GetAddOrKeywordLabel(int index)
    {
        return $"Add OR keyword for keyword search criterion {index + 1}";
    }

    private static string GetOrKeywordInputId(int criterionIndex, int orKeywordIndex)
    {
        return $"planning-keyword-{criterionIndex}-or-{orKeywordIndex}";
    }

    private static string GetOrKeywordLabel(int criterionIndex, int orKeywordIndex)
    {
        return $"OR keyword {orKeywordIndex + 1} for keyword search criterion {criterionIndex + 1}";
    }

    private static string GetSearchCriterionPlaceholder(int index)
    {
        return index == 0
            ? "Search documents, headings, descriptions"
            : "Additional keyword criteria";
    }
}
