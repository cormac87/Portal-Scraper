@using PortalScraper.Data

@if (Application is not null)
{
    <div class="modal-backdrop modal-backdrop-top" @onclick="OnClose">
        <section class="modal-panel documents-modal" role="dialog" aria-modal="true" aria-labelledby="documents-modal-title" @onclick:stopPropagation="true">
            <header class="modal-header">
                <div>
                    <p class="planning-authority">@PlanningDisplayFormatter.DisplayValue(Application.ApplicationReference)</p>
                    <h2 id="documents-modal-title">Documents (@Application.PlanningDocuments.Count)</h2>
                </div>
                <button class="secondary-button" type="button" @onclick="OnClose">Close</button>
            </header>

            <div class="document-list modal-document-list">
                @foreach (var document in Application.PlanningDocuments.OrderByDescending(document => document.PublishedDate).ThenBy(document => document.Name))
                {
                    var isExpanded = _expandedDocumentId == document.Id;
                    <article class="document-card modal-document-card"
                             role="button"
                             tabindex="0"
                             @key="document.Id"
                             @onclick="() => ToggleDocument(document.Id)"
                             @onkeydown="args => HandleDocumentCardKeyDown(document.Id, args)">
                        <header>
                            <div>
                                <h3>@document.Name</h3>
                                <p>@document.DocumentType | @PlanningDisplayFormatter.FormatDate(document.PublishedDate) | @PlanningDisplayFormatter.DisplayValue(document.ParseStatus)</p>
                            </div>
                            <button class="secondary-button" type="button" @onclick="() => ToggleDocument(document.Id)" @onclick:stopPropagation="true">
                                @(isExpanded ? "Minimize" : "View text")
                            </button>
                        </header>

                        @if (isExpanded)
                        {
                            <div class="document-expanded-content" @onclick:stopPropagation="true">
                                @if (!string.IsNullOrWhiteSpace(document.Url))
                                {
                                    <div class="planning-links">
                                        <a href="@document.Url" target="_blank" rel="noopener noreferrer">Open source document</a>
                                    </div>
                                }

                                @if (!string.IsNullOrWhiteSpace(document.ContentText))
                                {
                                    <pre>@document.ContentText</pre>
                                }
                                else if (!string.IsNullOrWhiteSpace(document.ParseError))
                                {
                                    <p class="document-error">@document.ParseError</p>
                                }
                                else
                                {
                                    <p class="document-empty">No extracted text was stored for this document.</p>
                                }
                            </div>
                        }
                    </article>
                }
            </div>
        </section>
    </div>
}

@code {
    private Guid? _expandedDocumentId;
    private Guid? _lastApplicationId;

    [Parameter]
    public PlanningApplication? Application { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    protected override void OnParametersSet()
    {
        if (Application?.Id == _lastApplicationId)
        {
            return;
        }

        _lastApplicationId = Application?.Id;
        _expandedDocumentId = null;
    }

    private void ToggleDocument(Guid documentId)
    {
        _expandedDocumentId = _expandedDocumentId == documentId ? null : documentId;
    }

    private void HandleDocumentCardKeyDown(Guid documentId, KeyboardEventArgs args)
    {
        if (args.Key is "Enter" or " " or "Spacebar")
        {
            ToggleDocument(documentId);
        }
    }
}
