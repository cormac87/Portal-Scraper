@using PortalScraper.Data

<section class="planning-summary">
    <article class="stat-card">
        <span>Authorities</span>
        <strong>@Authorities.Count(authority => !string.IsNullOrWhiteSpace(authority.Website))</strong>
    </article>
    <article class="stat-card">
        <span>Applications</span>
        <strong>@FormatCount(ApplicationTotalCount)</strong>
    </article>
    <article class="stat-card">
        <span>Documents</span>
        <strong>@FormatCount(DocumentTotalCount)</strong>
    </article>
</section>

@code {
    [Parameter]
    public IReadOnlyList<PlanningAuthority> Authorities { get; set; } = [];

    [Parameter]
    public int? ApplicationTotalCount { get; set; }

    [Parameter]
    public int? DocumentTotalCount { get; set; }

    private static string FormatCount(int? count)
    {
        return count.HasValue ? count.Value.ToString("N0") : "Loading";
    }
}
