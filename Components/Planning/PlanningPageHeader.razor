<section class="page-header">
    <div>
        <p class="eyebrow">Idox Public Access</p>
        <h1>Planning portal scraper</h1>
    </div>
    <div class="page-header-actions">
        <button class="secondary-button" type="button" @onclick="OnExport" disabled="@(!CanExportSearchResults)">
            Export Results to Excel
        </button>
        <button class="primary-button" type="button" @onclick="OnScrape" disabled="@IsScraping">
            @ScrapeButtonLabel
        </button>
    </div>
</section>

@code {
    [Parameter]
    public bool CanExportSearchResults { get; set; }

    [Parameter]
    public bool IsScraping { get; set; }

    [Parameter]
    public EventCallback OnExport { get; set; }

    [Parameter]
    public EventCallback OnScrape { get; set; }

    private string ScrapeButtonLabel => IsScraping ? "Scraping weekly..." : "Scrape Weekly";
}
