@page "/companies"
@implements IDisposable
@using System.Globalization
@using System.IO
@inject ICompanyDataService CompanyDataService
@inject ICompanyExcelExportService ExcelExportService
@inject ICompanyContactScraperService ContactScraperService
@inject IPostcodeGeocodingService PostcodeGeocodingService
@inject IJSRuntime JS

<PageTitle>Companies</PageTitle>

<section class="page-header">
    <div>
        <p class="eyebrow">Companies House</p>
        <h1>Companies</h1>
    </div>
    <div class="page-header-actions">
        <a class="secondary-button" href="/companies/upload">Upload company data</a>
        <a class="secondary-button" href="/companies/locations">Company locations</a>
        <button class="secondary-button" type="button" @onclick="ScrapeContactsAsync" disabled="@(!CanScrapeContacts)" title="@ScrapeContactsTitle">
            @ScrapeContactsButtonLabel
        </button>
        <button class="secondary-button" type="button" @onclick="OpenExportColumnsModal" disabled="@(!CanExportResults)">
            Export Results to Excel
        </button>
    </div>
</section>

<section class="planning-summary">
    <article class="stat-card">
        <span>Total companies</span>
        <strong>@CompanyTotalCountText</strong>
    </article>
    <article class="stat-card">
        <span>SIC codes</span>
        <strong>@SicCodeCountText</strong>
    </article>
</section>

<section class="planning-search">
    <form class="company-search-form" @onsubmit="SearchAsync" @onsubmit:preventDefault="true">
        <label>
            <span class="field-label">Company name</span>
            <input class="text-input"
                   value="@_companyName"
                   @oninput="OnCompanyNameInput"
                   placeholder="Search by company name" />
        </label>

        <label>
            <span class="field-label">SIC code</span>
            <input class="text-input"
                   type="search"
                   list="sic-code-options"
                   value="@_sicCodeSearchText"
                   @oninput="OnSicCodeSearchInput"
                   placeholder="@SicCodePlaceholder"
                   disabled="@_isLoadingSicCodes"
                   autocomplete="off" />
            <datalist id="sic-code-options">
                @foreach (var option in _sicCodeOptions)
                {
                    <option value="@option.Label"></option>
                }
            </datalist>
        </label>

        <label>
            <span class="field-label">Postcode</span>
            <input class="text-input"
                   value="@_locationFilter.Postcode"
                   @oninput="OnLocationPostcodeInput"
                   placeholder="SW1A 1AA"
                   autocomplete="postal-code" />
        </label>

        <label>
            <span class="field-label">Distance km</span>
            <input class="text-input"
                   type="number"
                   min="1"
                   step="1"
                   value="@_locationFilter.RadiusKm"
                   @oninput="OnLocationRadiusInput" />
        </label>

        <div class="planning-search-actions">
            <button class="primary-button" type="submit" disabled="@(_isSearching || _isResolvingLocation)">
                @SearchButtonLabel
            </button>
            <button class="secondary-button" type="button" @onclick="ClearSearchAsync" disabled="@(_isSearching || _isResolvingLocation)">
                Clear
            </button>
            @if (_lastFilters.Location is not null)
            {
                <button class="secondary-button" type="button" @onclick="ClearLocationAsync" disabled="@(_isSearching || _isResolvingLocation)">
                    Clear location
                </button>
            }
            <p class="search-summary">@PaginationSummary</p>
            @if (_lastFilters.Location is not null)
            {
                <p class="search-summary">@LocationSearchSummary</p>
            }
        </div>
    </form>
</section>

@if (!string.IsNullOrWhiteSpace(_locationErrorMessage))
{
    <p class="error-message">@_locationErrorMessage</p>
}

@if (_isExportColumnsModalOpen)
{
    <CompanyExportColumnsModal AvailableColumns="@ExportColumns"
                               ResultCount="@_companyResultCount"
                               OnDone="ExportSearchResultsAsync"
                               OnCancel="CloseExportColumnsModal" />
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <p class="error-message">@_errorMessage</p>
}

@if (_lastContactScrapeResult is not null)
{
    <section class="scrape-result">
        <h2>Contact scrape complete</h2>
        <p>
            @PlanningDisplayFormatter.FormatDateTime(_lastContactScrapeResult.StartedAtUtc)
            to @PlanningDisplayFormatter.FormatDateTime(_lastContactScrapeResult.FinishedAtUtc)
        </p>
        <ul>
            <li>Candidate companies: @_lastContactScrapeResult.CandidateCompanies.ToString("N0")</li>
            <li>Searched: @_lastContactScrapeResult.SearchedCompanies.ToString("N0")</li>
            <li>Skipped: @_lastContactScrapeResult.SkippedCompanies.ToString("N0")</li>
            <li>Emails found: @_lastContactScrapeResult.EmailsFound.ToString("N0")</li>
            <li>Emails updated: @_lastContactScrapeResult.EmailsUpdated.ToString("N0")</li>
            <li>Failed: @_lastContactScrapeResult.FailedCompanies.ToString("N0")</li>
        </ul>

        @if (_lastContactScrapeResult.Messages.Count > 0)
        {
            <details class="document-panel">
                <summary>Messages (@_lastContactScrapeResult.Messages.Count)</summary>
                <ul>
                    @foreach (var message in _lastContactScrapeResult.Messages)
                    {
                        <li>@message</li>
                    }
                </ul>
            </details>
        }
    </section>
}

@if (_isLoading || _isSearching)
{
    <section class="empty-state">
        <h2>Loading companies</h2>
        <p>Reading company records from the database.</p>
    </section>
}
else if (_companies.Count == 0)
{
    <section class="empty-state">
        <h2>No companies found</h2>
        <p>Upload company data or adjust the current search.</p>
    </section>
}
else
{
    <PaginationControls Summary="@PaginationSummary"
                        CurrentPage="@_companyPage"
                        TotalPages="@CompanyTotalPages"
                        HasNextPage="@_hasNextCompanyPage"
                        IsBusy="@(_isLoading || _isSearching)"
                        OnPrevious="PreviousCompanyPageAsync"
                        OnNext="NextCompanyPageAsync" />

    <section class="planning-list">
        @foreach (var company in _companies)
        {
            <CompanyCard @key="company.Id"
                         Company="@company"
                         OnOpen="OpenCompanyModalAsync" />
        }
    </section>

    <PaginationControls Summary="@PaginationSummary"
                        CurrentPage="@_companyPage"
                        TotalPages="@CompanyTotalPages"
                        HasNextPage="@_hasNextCompanyPage"
                        IsBusy="@(_isLoading || _isSearching)"
                        OnPrevious="PreviousCompanyPageAsync"
                        OnNext="NextCompanyPageAsync" />
}

@if (_isCompanyModalOpen && _selectedCompany is not null)
{
    <CompanyDetailsModal Company="@_selectedCompany"
                         OnClose="CloseCompanyModal" />
}

@code {
    private const int CompanyPageSize = 20;

    private List<Company> _companies = [];
    private List<CompanySicCodeOption> _sicCodeOptions = [];
    private CompanySearchFilters _lastFilters = CompanySearchFilters.Empty;
    private CompanyContactScrapeResult? _lastContactScrapeResult;
    private Company? _selectedCompany;
    private CompanyLocationFilterInput _locationFilter = new();
    private CompanyLocationSearch? _resolvedLocationSearch;
    private string? _companyName;
    private string? _selectedSicCode;
    private string? _sicCodeSearchText;
    private string? _errorMessage;
    private string? _locationErrorMessage;
    private int _companyPage = 1;
    private int? _companyTotalCount;
    private int? _companyResultCount;
    private CompanySearchFilters? _companyResultCountFilters;
    private int _companyResultCountRequestId;
    private CancellationTokenSource? _companyResultCountCts;
    private bool _isLoading = true;
    private bool _isSearching;
    private bool _isExporting;
    private bool _isScrapingContacts;
    private bool _isResolvingLocation;
    private bool _isLoadingSicCodes = true;
    private bool _isLoadingCompanyResultCount;
    private bool _hasNextCompanyPage;
    private bool _hasLoadedCompanyMetadata;
    private bool _isExportColumnsModalOpen;
    private bool _isCompanyModalOpen;

    private int? CompanyTotalPages => _companyResultCount.HasValue
        ? PlanningPagination.GetTotalPages(_companyResultCount.Value, CompanyPageSize)
        : null;
    private string PaginationSummary => _companyResultCount.HasValue
        ? PlanningPagination.GetSummary(_companyResultCount.Value, _companyPage, CompanyPageSize, "company")
        : GetCompanyPaginationSummaryWhileCounting();
    private string CompanyTotalCountText => _companyTotalCount.HasValue
        ? _companyTotalCount.Value.ToString("N0")
        : "Loading";
    private string SicCodeCountText => _isLoadingSicCodes
        ? "Loading"
        : _sicCodeOptions.Count.ToString("N0");
    private string SicCodePlaceholder => _isLoadingSicCodes
        ? "Loading SIC codes"
        : "All SIC codes";
    private string SearchButtonLabel => _isResolvingLocation
        ? "Finding location..."
        : _isSearching ? "Searching..." : "Search";
    private string ScrapeContactsButtonLabel => _isScrapingContacts ? "Scraping Contacts..." : "Scrape Contacts";
    private string ScrapeContactsTitle => _lastFilters.HasActive
        ? "Scrape contacts for the current filtered companies"
        : "Run a company name or SIC search before scraping contacts";
    private IReadOnlyList<CompanyExportColumn> ExportColumns => ExcelExportService.GetAvailableColumns();
    private string LocationSearchSummary => _lastFilters.Location is null
        ? string.Empty
        : $"Within {_lastFilters.Location.RadiusKm:0.#} km of {_lastFilters.Location.Postcode}";
    private bool CanExportResults => !_isLoading && !_isSearching && !_isResolvingLocation && !_isExporting && !_isScrapingContacts && _companies.Count > 0;
    private bool CanScrapeContacts => _lastFilters.HasActive && !_isLoading && !_isSearching && !_isResolvingLocation && !_isExporting && !_isScrapingContacts && _companies.Count > 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadCompanyPageAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _hasLoadedCompanyMetadata)
        {
            return;
        }

        _hasLoadedCompanyMetadata = true;
        await LoadCompanyMetadataAsync();
    }

    private async Task LoadCompanyMetadataAsync()
    {
        await LoadCompanyCountAsync();
        await LoadSicCodeOptionsAsync();
    }

    private string GetCompanyPaginationSummaryWhileCounting()
    {
        if (_companies.Count == 0)
        {
            return "0 company(s)";
        }

        var start = PlanningPagination.GetPageSkip(_companyPage, CompanyPageSize) + 1;
        var end = start + _companies.Count - 1;
        var suffix = _isLoadingCompanyResultCount
            ? ", counting total"
            : string.Empty;

        return $"Showing {start}-{end}{suffix} company(s)";
    }

    private async Task LoadCompanyCountAsync()
    {
        if (_companyTotalCount.HasValue)
        {
            if (!_lastFilters.HasActive)
            {
                SetCompanyResultCount(CompanySearchFilters.Empty, _companyTotalCount.Value);
            }

            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            _companyTotalCount = await CompanyDataService.GetCompanyCountAsync();
            if (!_lastFilters.HasActive)
            {
                SetCompanyResultCount(CompanySearchFilters.Empty, _companyTotalCount.Value);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load company count: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadSicCodeOptionsAsync()
    {
        _isLoadingSicCodes = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            _sicCodeOptions = (await CompanyDataService.GetSicCodeOptionsAsync()).ToList();
            SyncSicCodeSearchText();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load SIC codes: {ex.Message}";
        }
        finally
        {
            _isLoadingSicCodes = false;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task SearchAsync()
    {
        ResolveSicCodeSelection();
        var locationResolution = await ResolveLocationSearchAsync();
        if (!locationResolution.Success)
        {
            return;
        }

        _companyPage = 1;
        _companyResultCount = null;
        _companyResultCountFilters = null;
        _lastFilters = new CompanySearchFilters(_companyName, _selectedSicCode, locationResolution.Location);
        await LoadCompanyPageAsync();
    }

    private async Task ClearSearchAsync()
    {
        _companyName = null;
        ClearSicCodeSelection();
        _locationFilter = new CompanyLocationFilterInput();
        _resolvedLocationSearch = null;
        _locationErrorMessage = null;
        _companyPage = 1;
        _companyResultCount = _companyTotalCount;
        _companyResultCountFilters = _companyTotalCount.HasValue ? CompanySearchFilters.Empty : null;
        _lastFilters = CompanySearchFilters.Empty;
        await LoadCompanyPageAsync();
    }

    private async Task ClearLocationAsync()
    {
        _locationFilter = new CompanyLocationFilterInput();
        _resolvedLocationSearch = null;
        _locationErrorMessage = null;

        if (_lastFilters.Location is null)
        {
            return;
        }

        ResolveSicCodeSelection();
        _companyPage = 1;
        _companyResultCount = null;
        _companyResultCountFilters = null;
        _lastFilters = new CompanySearchFilters(_companyName, _selectedSicCode);
        await LoadCompanyPageAsync();
    }

    private async Task LoadCompanyPageAsync()
    {
        CancelCompanyResultCountLoad();
        _isLoading = !_isSearching;
        _isSearching = true;
        _isLoadingCompanyResultCount = false;
        _errorMessage = null;
        var filters = _lastFilters;

        try
        {
            var page = await CompanyDataService.SearchCompaniesAsync(filters, _companyPage, CompanyPageSize);
            _companies = page.Companies.ToList();
            _companyPage = page.CurrentPage;
            _hasNextCompanyPage = page.HasNextPage;

            var exactCount = page.TotalCount
                ?? InferCompanyResultCount(page.CurrentPage, page.Companies.Count, page.HasNextPage);
            if (exactCount.HasValue)
            {
                SetCompanyResultCount(filters, exactCount.Value);
            }
            else if (_companyResultCountFilters != filters)
            {
                _companyResultCount = null;
                _companyResultCountFilters = null;
            }

            if (!_companyResultCount.HasValue)
            {
                StartCompanyResultCountLoad(filters);
            }
        }
        catch (Exception ex)
        {
            _companies = [];
            _companyResultCount = 0;
            _companyResultCountFilters = filters;
            _hasNextCompanyPage = false;
            _errorMessage = $"Unable to load companies: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            _isSearching = false;
        }
    }

    private static int? InferCompanyResultCount(int currentPage, int loadedCount, bool hasNextPage)
    {
        return hasNextPage
            ? null
            : PlanningPagination.GetPageSkip(currentPage, CompanyPageSize) + loadedCount;
    }

    private void SetCompanyResultCount(CompanySearchFilters filters, int count)
    {
        _companyResultCount = count;
        _companyResultCountFilters = filters;
        _isLoadingCompanyResultCount = false;

        if (!filters.HasActive)
        {
            _companyTotalCount = count;
        }
    }

    private void StartCompanyResultCountLoad(CompanySearchFilters filters)
    {
        CancelCompanyResultCountLoad();
        _isLoadingCompanyResultCount = true;

        var requestId = ++_companyResultCountRequestId;
        var cts = new CancellationTokenSource();
        _companyResultCountCts = cts;
        _ = LoadCompanyResultCountInBackgroundAsync(filters, requestId, cts);
    }

    private async Task LoadCompanyResultCountInBackgroundAsync(
        CompanySearchFilters filters,
        int requestId,
        CancellationTokenSource cts)
    {
        try
        {
            var count = await CompanyDataService.GetCompanyCountAsync(filters, cts.Token);
            await InvokeAsync(() =>
            {
                if (cts.IsCancellationRequested || requestId != _companyResultCountRequestId)
                {
                    return;
                }

                SetCompanyResultCount(filters, count);
                StateHasChanged();
            });
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            await InvokeAsync(() =>
            {
                if (cts.IsCancellationRequested || requestId != _companyResultCountRequestId)
                {
                    return;
                }

                _isLoadingCompanyResultCount = false;
                _errorMessage = $"Unable to load filtered company count: {ex.Message}";
                StateHasChanged();
            });
        }
        finally
        {
            if (_companyResultCountCts == cts)
            {
                _companyResultCountCts = null;
            }

            cts.Dispose();
        }
    }

    private void CancelCompanyResultCountLoad()
    {
        _companyResultCountRequestId++;
        _isLoadingCompanyResultCount = false;
        _companyResultCountCts?.Cancel();
        _companyResultCountCts = null;
    }

    private async Task PreviousCompanyPageAsync()
    {
        if (_companyPage <= 1)
        {
            return;
        }

        _companyPage--;
        await LoadCompanyPageAsync();
    }

    private async Task NextCompanyPageAsync()
    {
        if (!_hasNextCompanyPage)
        {
            return;
        }

        _companyPage++;
        await LoadCompanyPageAsync();
    }

    private async Task OpenCompanyModalAsync(Guid companyId)
    {
        _errorMessage = null;

        try
        {
            var listedCompany = _companies.FirstOrDefault(company => company.Id == companyId);
            _selectedCompany = await CompanyDataService.GetCompanyAsync(companyId);

            if (_selectedCompany is null)
            {
                _isCompanyModalOpen = false;
                _errorMessage = "Unable to find the selected company.";
                return;
            }

            _selectedCompany.DistanceKm = listedCompany?.DistanceKm;
            _isCompanyModalOpen = true;
        }
        catch (Exception ex)
        {
            _isCompanyModalOpen = false;
            _selectedCompany = null;
            _errorMessage = $"Unable to load company details: {ex.Message}";
        }
    }

    private void CloseCompanyModal()
    {
        _isCompanyModalOpen = false;
        _selectedCompany = null;
    }

    private async Task ScrapeContactsAsync()
    {
        if (!CanScrapeContacts)
        {
            return;
        }

        _isScrapingContacts = true;
        _lastContactScrapeResult = null;
        _errorMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _lastContactScrapeResult = await ContactScraperService.ScrapeContactsAsync(_lastFilters);
            await LoadSicCodeOptionsAsync();
            await LoadCompanyPageAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to scrape company contacts: {ex.Message}";
        }
        finally
        {
            _isScrapingContacts = false;
        }
    }

    private void OpenExportColumnsModal()
    {
        if (!CanExportResults)
        {
            return;
        }

        _errorMessage = null;
        _isExportColumnsModalOpen = true;
    }

    private void CloseExportColumnsModal()
    {
        _isExportColumnsModalOpen = false;
    }

    private async Task ExportSearchResultsAsync(CompanyExportSelection selection)
    {
        _isExporting = true;
        _isExportColumnsModalOpen = false;
        _errorMessage = null;

        try
        {
            var result = await ExcelExportService.ExportSearchResultsAsync(new CompanyExcelExportRequest(
                _lastFilters,
                selection.ColumnKeys,
                selection.CustomColumns));

            using var stream = new MemoryStream(result.Content);
            using var streamReference = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("portalScraper.downloadFileFromStream", result.FileName, result.ContentType, streamReference);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to export companies: {ex.Message}";
        }
        finally
        {
            _isExporting = false;
        }
    }

    private void OnCompanyNameInput(ChangeEventArgs args)
    {
        _companyName = args.Value?.ToString();
    }

    private void OnSicCodeSearchInput(ChangeEventArgs args)
    {
        _sicCodeSearchText = args.Value?.ToString();
        _selectedSicCode = FindSicCodeOption(_sicCodeSearchText)?.Code;
    }

    private void OnLocationPostcodeInput(ChangeEventArgs args)
    {
        _locationFilter.Postcode = args.Value?.ToString() ?? string.Empty;
        if (!IsResolvedLocationCurrent())
        {
            _resolvedLocationSearch = null;
        }
    }

    private void OnLocationRadiusInput(ChangeEventArgs args)
    {
        if (double.TryParse(
            args.Value?.ToString(),
            NumberStyles.Float,
            CultureInfo.CurrentCulture,
            out var radiusKm))
        {
            _locationFilter.RadiusKm = radiusKm;
        }

        if (!IsResolvedLocationCurrent())
        {
            _resolvedLocationSearch = null;
        }
    }

    private async Task<LocationResolution> ResolveLocationSearchAsync()
    {
        _locationErrorMessage = null;
        var postcode = _locationFilter.Postcode.Trim();
        if (string.IsNullOrWhiteSpace(postcode))
        {
            _resolvedLocationSearch = null;
            return new LocationResolution(true, null);
        }

        if (_locationFilter.RadiusKm <= 0)
        {
            _locationErrorMessage = "Enter a distance greater than 0 km.";
            return new LocationResolution(false, null);
        }

        if (IsResolvedLocationCurrent() && _resolvedLocationSearch is not null)
        {
            return new LocationResolution(true, _resolvedLocationSearch);
        }

        _isResolvingLocation = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var coordinate = await PostcodeGeocodingService.GeocodePostcodeAsync(postcode);
            _resolvedLocationSearch = new CompanyLocationSearch(
                postcode,
                coordinate.Latitude,
                coordinate.Longitude,
                _locationFilter.RadiusKm);

            return new LocationResolution(true, _resolvedLocationSearch);
        }
        catch (Exception ex)
        {
            _resolvedLocationSearch = null;
            _locationErrorMessage = $"Unable to find nearby companies: {ex.Message}";
            return new LocationResolution(false, null);
        }
        finally
        {
            _isResolvingLocation = false;
        }
    }

    private bool IsResolvedLocationCurrent()
    {
        return _resolvedLocationSearch is not null
            && string.Equals(
                _resolvedLocationSearch.Postcode.Trim(),
                _locationFilter.Postcode.Trim(),
                StringComparison.OrdinalIgnoreCase)
            && Math.Abs(_resolvedLocationSearch.RadiusKm - _locationFilter.RadiusKm) < 0.001;
    }

    private void ResolveSicCodeSelection()
    {
        if (string.IsNullOrWhiteSpace(_sicCodeSearchText))
        {
            ClearSicCodeSelection();
            return;
        }

        var option = FindSicCodeOption(_sicCodeSearchText);
        _selectedSicCode = option?.Code;
        if (option is not null)
        {
            _sicCodeSearchText = option.Label;
        }
    }

    private void SyncSicCodeSearchText()
    {
        if (string.IsNullOrWhiteSpace(_selectedSicCode))
        {
            return;
        }

        var option = _sicCodeOptions.FirstOrDefault(option =>
            string.Equals(option.Code, _selectedSicCode, StringComparison.OrdinalIgnoreCase));
        if (option is not null)
        {
            _sicCodeSearchText = option.Label;
        }
    }

    private CompanySicCodeOption? FindSicCodeOption(string? searchText)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return null;
        }

        var text = searchText.Trim();
        var exactOption = _sicCodeOptions.FirstOrDefault(option =>
            string.Equals(option.Code, text, StringComparison.OrdinalIgnoreCase)
            || string.Equals(option.Label, text, StringComparison.OrdinalIgnoreCase));
        if (exactOption is not null)
        {
            return exactOption;
        }

        var separatorIndex = text.IndexOf(" - ", StringComparison.Ordinal);
        if (separatorIndex <= 0)
        {
            return null;
        }

        var code = text[..separatorIndex].Trim();
        return _sicCodeOptions.FirstOrDefault(option =>
            string.Equals(option.Code, code, StringComparison.OrdinalIgnoreCase));
    }

    private void ClearSicCodeSelection()
    {
        _selectedSicCode = null;
        _sicCodeSearchText = null;
    }

    private sealed record LocationResolution(
        bool Success,
        CompanyLocationSearch? Location);

    public void Dispose()
    {
        CancelCompanyResultCountLoad();
    }
}
