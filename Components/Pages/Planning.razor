@page "/planning"
@using System.IO
@inject IPlanningDataService PlanningDataService
@inject IPlanningSearchService PlanningSearchService
@inject IPlanningPortalScraper Scraper
@inject IPlanningApplicationExcelExportService ExcelExportService
@inject IPlanningAuthorityLocationService AuthorityLocationService
@inject IPostcodeGeocodingService PostcodeGeocodingService
@inject IJSRuntime JS

<PageTitle>Planning Portal Scraper</PageTitle>

<PlanningPageHeader CanExportSearchResults="@CanExportSearchResults"
                    IsScraping="@_isScraping"
                    OnExport="OpenExportColumnsModal"
                    OnScrape="ScrapeWeeklyAsync" />

<PlanningSummaryCards Authorities="@_authorities"
                      ApplicationTotalCount="@_applicationTotalCount"
                      DocumentTotalCount="@_documentTotalCount" />

<PlanningSearchPanel Criteria="@_searchCriteria"
                     LocationFilter="@_locationFilter"
                     IsSearching="@_isSearching"
                     IsFindingLocationAuthorities="@_isFindingLocationAuthorities"
                     LocationErrorMessage="@_locationErrorMessage"
                     SearchHasRun="@_searchHasRun"
                     LastSearchText="@_lastSearchText"
                     SearchPaginationSummary="@SearchPaginationSummary"
                     OnSearch="SearchAsync"
                     OnAddCriterion="AddSearchCriterion"
                     OnRemoveCriterion="RemoveSearchCriterion"
                     OnOpenSettings="OpenSearchSettingsModal"
                     OnFindLocationAuthorities="FindLocationAuthoritiesAsync"
                     OnClearLocationFilter="ClearLocationFilter"
                     OnClear="ClearSearch" />

@if (_isSearchSettingsModalOpen && _selectedSearchCriterion is not null)
{
    <PlanningSearchSettingsModal Criterion="@_selectedSearchCriterion"
                                 Context="@GetSearchCriterionSettingsContext(_selectedSearchCriterion)"
                                 OnClose="CloseSearchSettingsModal" />
}

@if (_isExportColumnsModalOpen)
{
    <PlanningExportColumnsModal AvailableColumns="@ExportColumns"
                                ResultCount="@_searchTotalCount"
                                OnDone="ExportSearchResultsAsync"
                                OnCancel="CloseExportColumnsModal" />
}

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <p class="error-message">@_errorMessage</p>
}

<PlanningScrapeResultPanel Result="@_lastResult" />

@if (_searchHasRun)
{
    <PlanningSearchResults Results="@_searchResults"
                           Summary="@SearchPaginationSummary"
                           CurrentPage="@_searchPage"
                           TotalPages="@SearchTotalPages"
                           IsSearching="@_isSearching"
                           OnPrevious="PreviousSearchPageAsync"
                           OnNext="NextSearchPageAsync"
                           OnOpenApplication="OpenApplicationModalAsync" />
}
else
{
    <PlanningApplicationList Applications="@_applications"
                             Summary="@ApplicationPaginationSummary"
                             CurrentPage="@_applicationPage"
                             TotalPages="@ApplicationTotalPages"
                             IsLoading="@_isLoading"
                             OnPrevious="PreviousApplicationPageAsync"
                             OnNext="NextApplicationPageAsync"
                             OnOpenApplication="OpenApplicationModalAsync" />
}

@if (_isApplicationModalOpen && _selectedApplication is not null)
{
    <PlanningApplicationModal Application="@_selectedApplication"
                              CanShowRelevantDocuments="@CanShowRelevantDocuments"
                              OnClose="CloseApplicationModal"
                              OnOpenDocuments="OpenDocumentsModal"
                              OnOpenRelevantDocuments="OpenRelevantDocumentsModal" />
}

@if (_isDocumentsModalOpen && _selectedApplication is not null)
{
    <PlanningDocumentsModal Application="@_selectedApplication"
                            OnClose="CloseDocumentsModal" />
}

@if (_isRelevantDocumentsModalOpen && _selectedApplication is not null)
{
    <RelevantPlanningDocumentsModal Application="@_selectedApplication"
                                    Criteria="@GetRelevantDocumentCriteria()"
                                    OnClose="CloseRelevantDocumentsModal" />
}

@code {
    private const int ApplicationPageSize = 20;
    private const int SearchPageSize = 20;

    private List<PlanningAuthority> _authorities = [];
    private List<PlanningApplication> _applications = [];
    private List<PlanningSearchResult> _searchResults = [];
    private List<PlanningSearchCriterionInput> _searchCriteria = [new()];
    private List<string> _lastSearchConditions = [];
    private List<FullTextSearchCriterion> _lastSearchCriteria = [];
    private List<Guid>? _lastSearchAuthorityIds;
    private PlanningLocationFilterInput _locationFilter = new();
    private WeeklyScrapeResult? _lastResult;
    private int _applicationPage = 1;
    private int _applicationTotalCount;
    private int _documentTotalCount;
    private int _searchPage = 1;
    private int _searchTotalCount;
    private bool _isLoading = true;
    private bool _isScraping;
    private bool _isSearching;
    private bool _isFindingLocationAuthorities;
    private bool _searchHasRun;
    private bool _isApplicationModalOpen;
    private bool _isDocumentsModalOpen;
    private bool _isRelevantDocumentsModalOpen;
    private bool _isSearchSettingsModalOpen;
    private bool _isExportColumnsModalOpen;
    private bool _isExporting;
    private PlanningApplication? _selectedApplication;
    private PlanningSearchCriterionInput? _selectedSearchCriterion;
    private string? _errorMessage;
    private string? _locationErrorMessage;
    private string? _lastSearchText;

    private int ApplicationTotalPages => PlanningPagination.GetTotalPages(_applicationTotalCount, ApplicationPageSize);
    private int SearchTotalPages => PlanningPagination.GetTotalPages(_searchTotalCount, SearchPageSize);
    private string ApplicationPaginationSummary => PlanningPagination.GetSummary(_applicationTotalCount, _applicationPage, ApplicationPageSize, "application");
    private string SearchPaginationSummary => PlanningPagination.GetSummary(_searchTotalCount, _searchPage, SearchPageSize, "planning application");
    private IReadOnlyList<PlanningApplicationExportColumn> ExportColumns => ExcelExportService.GetAvailableColumns();
    private bool CanExportSearchResults => _searchHasRun
        && !_isSearching
        && !_isExporting
        && _searchTotalCount > 0
        && (_lastSearchConditions.Count > 0 || _lastSearchAuthorityIds is not null);
    private bool CanShowRelevantDocuments => _selectedApplication?.PlanningDocuments.Count > 0 && GetRelevantDocumentCriteria().Count > 0;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task ScrapeWeeklyAsync()
    {
        _isScraping = true;
        _errorMessage = null;

        try
        {
            _lastResult = await Scraper.ScrapeWeeklyAsync();
            _applicationPage = 1;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to run weekly scrape: {ex.Message}";
        }
        finally
        {
            _isScraping = false;
        }
    }

    private async Task RefreshAsync()
    {
        _isLoading = true;

        try
        {
            var overview = await PlanningDataService.GetOverviewPageAsync(_applicationPage, ApplicationPageSize);

            _authorities = overview.Authorities.ToList();
            _applications = overview.Applications.ToList();
            _applicationPage = overview.CurrentPage;
            _applicationTotalCount = overview.ApplicationTotalCount;
            _documentTotalCount = overview.DocumentTotalCount;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load planning data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SearchAsync()
    {
        var searchCriteria = PlanningSearchService.BuildCriteria(_searchCriteria);
        var authorityFilterIds = GetActiveAuthorityFilterIds();
        if (searchCriteria.Count == 0 && authorityFilterIds is null)
        {
            ClearSearch();
            return;
        }

        _isSearching = true;
        _searchHasRun = true;
        _searchPage = 1;
        _searchTotalCount = 0;
        _searchResults = [];
        _lastSearchText = BuildSearchSummary(searchCriteria, authorityFilterIds);
        _lastSearchConditions = searchCriteria
            .Select(criterion => criterion.SearchCondition)
            .ToList();
        _lastSearchCriteria = searchCriteria;
        _lastSearchAuthorityIds = authorityFilterIds?.ToList();
        _errorMessage = null;

        await LoadSearchPageAsync();
    }

    private async Task LoadSearchPageAsync()
    {
        if (_lastSearchCriteria.Count == 0 && _lastSearchAuthorityIds is null)
        {
            ClearSearch();
            return;
        }

        _isSearching = true;
        _errorMessage = null;

        try
        {
            var searchPage = await PlanningSearchService.SearchAsync(
                _lastSearchCriteria,
                _searchPage,
                SearchPageSize,
                _lastSearchAuthorityIds);
            if (!searchPage.IsFullTextSearchAvailable)
            {
                _searchHasRun = false;
                _searchResults = [];
                _errorMessage = "Keyword search requires SQL Server Full-Text Search and the planning full-text indexes. Install the SQL Server Full-Text feature, then run the schema update script.";
                return;
            }

            _searchPage = searchPage.CurrentPage;
            _searchTotalCount = searchPage.TotalCount;
            _searchResults = searchPage.Results.ToList();
        }
        catch (Exception ex)
        {
            _searchResults = [];
            _searchTotalCount = 0;
            _errorMessage = $"Unable to run keyword search: {ex.Message}";
        }
        finally
        {
            _isSearching = false;
        }
    }

    private void ClearSearch()
    {
        _searchResults = [];
        _searchHasRun = false;
        _searchPage = 1;
        _searchTotalCount = 0;
        _lastSearchConditions = [];
        _lastSearchCriteria = [];
        _lastSearchAuthorityIds = null;
        _lastSearchText = null;
    }

    private async Task FindLocationAuthoritiesAsync()
    {
        _isFindingLocationAuthorities = true;
        _locationErrorMessage = null;

        try
        {
            var coordinate = await PostcodeGeocodingService.GeocodePostcodeAsync(_locationFilter.Postcode);
            var authorities = await AuthorityLocationService.FindAuthoritiesWithinRadiusAsync(
                coordinate.Latitude,
                coordinate.Longitude,
                _locationFilter.RadiusKm);

            _locationFilter.HasResolved = true;
            _locationFilter.Authorities = authorities
                .Select(authority => new PlanningAuthorityLocationSelection
                {
                    Id = authority.Id,
                    Name = authority.Name,
                    Latitude = authority.Latitude,
                    Longitude = authority.Longitude,
                    DistanceKm = authority.DistanceKm,
                    IsSelected = true
                })
                .ToList();
        }
        catch (Exception ex)
        {
            _locationErrorMessage = $"Unable to find nearby authorities: {ex.Message}";
        }
        finally
        {
            _isFindingLocationAuthorities = false;
        }
    }

    private void ClearLocationFilter()
    {
        _locationFilter = new PlanningLocationFilterInput();
        _locationErrorMessage = null;
    }

    private void AddSearchCriterion()
    {
        _searchCriteria.Add(new PlanningSearchCriterionInput());
    }

    private void RemoveSearchCriterion(PlanningSearchCriterionInput criterion)
    {
        if (_searchCriteria.Count <= 1)
        {
            return;
        }

        _searchCriteria.Remove(criterion);
        if (ReferenceEquals(_selectedSearchCriterion, criterion))
        {
            CloseSearchSettingsModal();
        }

        if (_searchCriteria.Count == 0)
        {
            _searchCriteria.Add(new PlanningSearchCriterionInput());
        }
    }

    private void OpenSearchSettingsModal(PlanningSearchCriterionInput criterion)
    {
        _selectedSearchCriterion = criterion;
        _isSearchSettingsModalOpen = true;
    }

    private void CloseSearchSettingsModal()
    {
        _isSearchSettingsModalOpen = false;
        _selectedSearchCriterion = null;
    }

    private void OpenExportColumnsModal()
    {
        if (!CanExportSearchResults)
        {
            return;
        }

        _errorMessage = null;
        _isExportColumnsModalOpen = true;
    }

    private void CloseExportColumnsModal()
    {
        _isExportColumnsModalOpen = false;
    }

    private async Task ExportSearchResultsAsync(PlanningApplicationExportSelection selection)
    {
        if (_lastSearchConditions.Count == 0 && _lastSearchAuthorityIds is null)
        {
            _isExportColumnsModalOpen = false;
            return;
        }

        _isExporting = true;
        _isExportColumnsModalOpen = false;
        _errorMessage = null;

        try
        {
            var result = await ExcelExportService.ExportSearchResultsAsync(new PlanningApplicationExcelExportRequest(
                _lastSearchConditions.ToList(),
                selection.ColumnKeys,
                selection.CustomColumns,
                _lastSearchAuthorityIds?.ToList()));

            using var stream = new MemoryStream(result.Content);
            using var streamReference = new DotNetStreamReference(stream);
            await JS.InvokeVoidAsync("portalScraper.downloadFileFromStream", result.FileName, result.ContentType, streamReference);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to export planning results: {ex.Message}";
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task PreviousApplicationPageAsync()
    {
        if (_applicationPage <= 1)
        {
            return;
        }

        _applicationPage--;
        await RefreshAsync();
    }

    private async Task NextApplicationPageAsync()
    {
        if (_applicationPage >= ApplicationTotalPages)
        {
            return;
        }

        _applicationPage++;
        await RefreshAsync();
    }

    private async Task PreviousSearchPageAsync()
    {
        if (_searchPage <= 1)
        {
            return;
        }

        _searchPage--;
        await LoadSearchPageAsync();
    }

    private async Task NextSearchPageAsync()
    {
        if (_searchPage >= SearchTotalPages)
        {
            return;
        }

        _searchPage++;
        await LoadSearchPageAsync();
    }

    private async Task OpenApplicationModalAsync(Guid applicationId)
    {
        _errorMessage = null;
        _isDocumentsModalOpen = false;
        _isRelevantDocumentsModalOpen = false;

        try
        {
            _selectedApplication = await PlanningDataService.GetApplicationAsync(applicationId);

            if (_selectedApplication is null)
            {
                _isApplicationModalOpen = false;
                _errorMessage = "Unable to find the selected planning application.";
                return;
            }

            _isApplicationModalOpen = true;
        }
        catch (Exception ex)
        {
            _isApplicationModalOpen = false;
            _selectedApplication = null;
            _errorMessage = $"Unable to load planning application details: {ex.Message}";
        }
    }

    private void CloseApplicationModal()
    {
        _isApplicationModalOpen = false;
        _isDocumentsModalOpen = false;
        _isRelevantDocumentsModalOpen = false;
        _selectedApplication = null;
    }

    private void OpenDocumentsModal()
    {
        if (_selectedApplication?.PlanningDocuments.Count > 0)
        {
            _isDocumentsModalOpen = true;
            _isRelevantDocumentsModalOpen = false;
        }
    }

    private void OpenRelevantDocumentsModal()
    {
        if (_selectedApplication?.PlanningDocuments.Count is null or 0)
        {
            return;
        }

        if (GetRelevantDocumentCriteria().Count == 0)
        {
            return;
        }

        _isDocumentsModalOpen = false;
        _isRelevantDocumentsModalOpen = true;
    }

    private void CloseDocumentsModal()
    {
        _isDocumentsModalOpen = false;
    }

    private void CloseRelevantDocumentsModal()
    {
        _isRelevantDocumentsModalOpen = false;
    }

    private List<FullTextSearchCriterion> GetRelevantDocumentCriteria()
    {
        return _lastSearchCriteria.Count > 0
            ? _lastSearchCriteria
            : PlanningSearchService.BuildCriteria(_searchCriteria);
    }

    private List<Guid>? GetActiveAuthorityFilterIds()
    {
        return _locationFilter.HasResolved
            ? _locationFilter.SelectedAuthorityIds.ToList()
            : null;
    }

    private string BuildSearchSummary(
        IReadOnlyList<FullTextSearchCriterion> criteria,
        IReadOnlyList<Guid>? authorityFilterIds)
    {
        var parts = new List<string>();
        if (criteria.Count > 0)
        {
            parts.Add(PlanningSearchService.FormatCriteriaSummary(criteria));
        }

        if (authorityFilterIds is not null)
        {
            parts.Add($"{authorityFilterIds.Count} of {_locationFilter.Authorities.Count} authorities near {_locationFilter.Postcode.Trim()}");
        }

        return parts.Count == 0
            ? "planning applications"
            : string.Join(" + ", parts);
    }

    private string GetSearchCriterionSettingsContext(PlanningSearchCriterionInput criterion)
    {
        var index = _searchCriteria.IndexOf(criterion);

        return index >= 0
            ? $"Keyword search criterion {index + 1}"
            : "Keyword search";
    }
}
