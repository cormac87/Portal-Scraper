    private static int GetPageSkip(int page, int pageSize)
    {
        return (Math.Max(1, page) - 1) * pageSize;
    }

    private static int GetTotalPages(int totalCount, int pageSize)
    {
        return Math.Max(1, (int)Math.Ceiling(totalCount / (double)pageSize));
    }

    private static string GetPaginationSummary(int totalCount, int currentPage, int pageSize, string itemName)
    {
        if (totalCount == 0)
        {
            return $"0 {itemName}(s)";
        }

        var start = GetPageSkip(currentPage, pageSize) + 1;
        var end = Math.Min(totalCount, currentPage * pageSize);

        return $"Showing {start}-{end} of {totalCount} {itemName}(s)";
    }

