<nav class="pagination-controls" aria-label="Pagination">
    <span>@Summary</span>
    <div>
        <button class="secondary-button" type="button" @onclick="OnPrevious" disabled="@(IsBusy || CurrentPage <= 1)">
            Previous
        </button>
        <span>@PageLabel</span>
        <button class="secondary-button" type="button" @onclick="OnNext" disabled="@(IsBusy || !CanGoNext)">
            Next
        </button>
    </div>
</nav>

@code {
    [Parameter]
    public string Summary { get; set; } = string.Empty;

    [Parameter]
    public int CurrentPage { get; set; } = 1;

    [Parameter]
    public int? TotalPages { get; set; } = 1;

    [Parameter]
    public bool? HasNextPage { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnPrevious { get; set; }

    [Parameter]
    public EventCallback OnNext { get; set; }

    private bool CanGoNext => HasNextPage ?? (TotalPages.HasValue && CurrentPage < TotalPages.Value);

    private string PageLabel => TotalPages.HasValue
        ? $"Page {CurrentPage} of {TotalPages.Value}"
        : $"Page {CurrentPage}";
}
